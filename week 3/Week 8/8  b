<!DOCTYPE html>
<html>
    <head>
        <title>Moving Ball</title>
        <style>
            .container{
                display:flex;
                min-height: 100vh;
                justify-content: center;
                align-items: center;
            }
            .content{
                border: 1px solid black;
                width: 350px;
                height: 600px;
                display: flex;
                justify-content: center;
                align-items: center;
            }
            .moving-ball{
                width: 50px;
                height: 50px;
                background-color: red;
                border-radius: 100%;
                animation: ball;
                animation-timing-function: linear;
                animation-duration: 1s;
                animation-iteration-count: infinite;
            }
            @keyframes ball{
                0%{
                    transform: translate(0,0);
                }
                50%{
                    transform: translate(0,300px);
                }
                100%{
                    transform: translate(0,0);
                }
            }
        </style>
    </head>
    <body>
        <div class="container">
            <div class="content">
                <div class="moving-ball"></div>
            </div>
        </div>
        
    </body>
</html>