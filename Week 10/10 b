<!DOCTYPE html>
<html>
<head>
    <title>Sort Three Numbers</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea, #764ba2);
            background-image: url("https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQCSiV_bsTY7NpHYHu7aTWoCbigVy217B_nNg&s=10");
            background-size: cover;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            background: #ffffff;
            padding: 25px 30px;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            text-align: center;
            width: 300px;
        }

        h2 {
            margin-bottom: 15px;
            color: #333;
        }

        input {
            width: 80%;
            padding: 8px;
            margin: 6px 0;
            border-radius: 6px;
            border: 1px solid #ccc;
            outline: none;
        }

        input:focus {
            border-color: #667eea;
        }

        button {
            margin-top: 10px;
            padding: 10px 18px;
            border: none;
            border-radius: 8px;
            background: #667eea;
            color: white;
            font-size: 14px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: #5a67d8;
        }

        .note {
            font-size: 12px;
            color: gray;
            margin-top: 8px;
        }
    </style>

</head>
<body>

<div class="container">
    <h2>Sort 3 Numbers</h2>

    <input type="number" id="num1" placeholder="Enter first number">
    <input type="number" id="num2" placeholder="Enter second number">
    <input type="number" id="num3" placeholder="Enter third number">

    <br>
    <button onclick="sortNumbers()">Sort Now</button>

    <p class="note">Result will be shown in alert box</p>
</div>

<script>
function sortNumbers() {
    let a = parseFloat(document.getElementById("num1").value);
    let b = parseFloat(document.getElementById("num2").value);
    let c = parseFloat(document.getElementById("num3").value);

    let first, second, third;

    // basic validation (small human touch 😅)
    if (isNaN(a) || isNaN(b) || isNaN(c)) {
        alert("Please enter all three numbers properly!");
        return;
    }

    // sorting logic (descending)
    if (a >= b && a >= c) {
        first = a;

        if (b >= c) {
            second = b;
            third = c;
        } else {
            second = c;
            third = b;
        }
    }
    else if (b >= a && b >= c) {
        first = b;

        if (a >= c) {
            second = a;
            third = c;
        } else {
            second = c;
            third = a;
        }
    }
    else {
        first = c;

        if (a >= b) {
            second = a;
            third = b;
        } else {
            second = b;
            third = a;
        }
    }

    alert("Sorted numbers: " + first + ", " + second + ", " + third);
}
</script>

</body>
</html>