<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moving Rotating Circle</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      align-items: center;
      background: #111;
      overflow: hidden;
    }

    .circle {
      width: 100px;
      height: 100px;
      background: linear-gradient(135deg, #00f5ff, #0077ff);
      border-radius: 50%;
      position: relative;
      animation: moveRotate 4s linear infinite alternate;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* line inside to show rotation clearly */
    .circle::before {
      content: "";
      width: 50px;
      height: 6px;
      background: white;
      border-radius: 10px;
      position: absolute;
    }

    @keyframes moveRotate {
      0% {
        transform: translateX(0) rotate(0deg);
      }
      100% {
        transform: translateX(800px) rotate(360deg);
      }
    }
  </style>
</head>
<body>

  <div class="circle"></div>

</body>
</html>